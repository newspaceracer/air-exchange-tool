---
// SMAQMD — Home. The hub for the spoke: the layers of the repo — the
// Design System (live), the Pattern Library (coming soon), and the Prototypes
// (working screens, straight off the typed registry in src/data/prototypes.ts).
import BaseLayout from '../layouts/BaseLayout.astro';
import { withBase } from '../lib/base';
import { prototypesByNewest, type PrototypeStatus } from '../data/prototypes';

const rows = prototypesByNewest();

const MONTHS = ['Jan', 'Feb', 'Mar', 'Apr', 'May', 'Jun', 'Jul', 'Aug', 'Sep', 'Oct', 'Nov', 'Dec'];
// Format from the ISO parts directly — avoids new Date() timezone drift that can
// roll a UTC-midnight date back a day in the build environment.
const fmtDate = (iso: string): string => {
  const [y, m, d] = iso.split('-').map(Number);
  return `${MONTHS[m - 1]} ${d}, ${y}`;
};

const STATUS_LABEL: Record<PrototypeStatus, string> = {
  live: 'Live',
  'in-progress': 'In progress',
  planned: 'Planned',
  archived: 'Archived',
};
---
<BaseLayout title="SMAQMD — Design & Prototypes">
  <main class="home">
    <header class="hero">
      <p class="hero__eyebrow">Spoke of ESA Ecology</p>
      <h1 class="hero__title">SMAQMD Design &amp; Prototypes</h1>
      <p class="hero__tagline">
        Design system and prototypes for SMAQMD — built on the <code>@esa/ecology</code> hub and themed
        for SMAQMD, in one place.
      </p>
    </header>

    <section class="layers" aria-label="Layers">
      <a class="layer" href={withBase('/design-system')}>
        <span class="layer__status layer__status--live"><span class="dot"></span>Live</span>
        <h2 class="layer__title">Design System</h2>
        <p class="layer__body">The brand layer — SMAQMD's palette, type, and form sizing, plus the inherited Ecology components re-skinned for SMAQMD.</p>
        <span class="layer__go">Open the design system<svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M5 12h14"/><path d="m12 5 7 7-7 7"/></svg></span>
      </a>

      <a class="layer layer--soon" href={withBase('/patterns')}>
        <span class="layer__status layer__status--soon"><span class="dot"></span>Coming soon</span>
        <h2 class="layer__title">Pattern Library</h2>
        <p class="layer__body">Composed, multi-component patterns — app shells, tables, and flows — assembled from the system.</p>
        <span class="layer__go">Preview<svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M5 12h14"/><path d="m12 5 7 7-7 7"/></svg></span>
      </a>
    </section>

    <section class="protos" aria-label="Prototypes">
      <div class="protos__head">
        <h2>Prototypes</h2>
        <p>Working screens for the platform, built on the system.</p>
      </div>
      <ul class="proto-list">
        {rows.map((p) => (
          <li class="proto-card">
            <a class="proto-card__link" href={withBase(p.route)}>
              <span class="proto-card__title">
                {p.title}
                <svg class="proto-card__arrow" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M7 17 17 7"/><path d="M7 7h10v10"/></svg>
              </span>
            </a>
            <p class="proto-card__desc">{p.description}</p>
            <div class="proto-card__foot">
              <span class="lib-status" data-status={p.status}>
                <span class="lib-status__dot" aria-hidden="true"></span>
                {STATUS_LABEL[p.status]}
              </span>
              <time class="proto-card__meta" datetime={p.createdAt}>{fmtDate(p.createdAt)}</time>
              {p.ticket && <span class="proto-card__meta">{p.ticket}</span>}
            </div>
          </li>
        ))}
      </ul>
    </section>

    <footer class="home__foot">
      <span>SMAQMD — a brand spoke of ESA Ecology.</span>
    </footer>
  </main>

  <style>
    .home { max-width: 1040px; margin: 0 auto; padding: 0 var(--spacing-500, 24px); background: var(--color-surface, #fff); }

    /* ---- Hero ---- */
    .hero {
      display: flex; flex-direction: column; align-items: center; text-align: center;
      padding: var(--spacing-900, 96px) 0 var(--spacing-800, 64px);
    }
    .hero__eyebrow {
      margin: 0;
      font-size: var(--type-size-100, 0.875rem);
      font-weight: var(--font-weight-medium, 450);
      letter-spacing: 0.04em; text-transform: uppercase;
      color: var(--color-secondary, #00918b);
    }
    .hero__title {
      margin: var(--spacing-200, 8px) 0 0;
      font-family: var(--font-display, var(--font-sans));
      font-weight: var(--font-weight-semibold, 550);
      font-size: clamp(2.5rem, 1.9rem + 3vw, 4rem);
      line-height: 1.04; letter-spacing: -0.02em;
      color: var(--color-text-primary, #3d3d3d);
    }
    .hero__tagline {
      margin: var(--spacing-400, 16px) auto 0; max-width: 58ch;
      font-size: var(--type-size-300, 1.125rem); line-height: 1.6;
      color: var(--color-text-secondary, #525252);
    }
    code { font-family: var(--font-mono, monospace); font-size: 0.9em; background: var(--color-surface-sunken, #efefef); padding: 0.1em 0.35em; border-radius: var(--radius-100, 4px); }

    /* ---- Layer cards ---- */
    .layers { display: grid; grid-template-columns: 1fr 1fr; gap: var(--spacing-400, 16px); padding-bottom: var(--spacing-800, 64px); }
    .layer {
      position: relative; display: flex; flex-direction: column;
      padding: var(--spacing-600, 32px);
      border: 1px solid var(--color-border, #dcdcdc); border-radius: var(--radius-400, 12px);
      background: var(--color-surface, #fff);
      transition: border-color 0.14s ease, box-shadow 0.14s ease, transform 0.14s ease;
    }
    .layer:hover {
      border-color: var(--color-primary-border, #cfe2ee);
      box-shadow: 0 12px 32px color-mix(in srgb, var(--color-primary, #43608a) 12%, transparent);
      transform: translateY(-2px);
    }
    .layer--soon { background: var(--color-surface-sunken, #efefef); }
    .layer__status { display: inline-flex; align-items: center; gap: var(--spacing-150, 6px); font-size: var(--type-size-100, 0.875rem); font-weight: var(--font-weight-medium, 450); }
    .layer__status .dot { width: 8px; height: 8px; border-radius: 50%; }
    .layer__status--live { color: #1a6f3f; }
    .layer__status--live .dot { background: #1a9b54; }
    .layer__status--soon { color: var(--color-text-muted, #7c7c7c); }
    .layer__status--soon .dot { background: var(--color-secondary, #00918b); }
    .layer__title {
      margin: var(--spacing-300, 12px) 0 var(--spacing-200, 8px);
      font-family: var(--font-display, var(--font-sans));
      font-size: var(--type-size-600, 2rem); font-weight: var(--font-weight-semibold, 550);
      letter-spacing: -0.01em; color: var(--color-text-primary, #3d3d3d);
    }
    .layer__body { margin: 0; font-size: var(--type-size-200, 1rem); line-height: 1.55; color: var(--color-text-secondary, #525252); }
    .layer__go {
      display: inline-flex; align-items: center; gap: var(--spacing-150, 6px);
      margin-top: var(--spacing-500, 24px);
      font-weight: var(--font-weight-semibold, 550); font-size: var(--type-size-200, 1rem);
      color: var(--color-text-link, #43608a);
    }
    .layer__go svg { transition: transform 0.14s ease; }
    .layer:hover .layer__go svg { transform: translateX(3px); }
    .layer--soon .layer__go { color: var(--color-text-muted, #7c7c7c); }

    /* ---- Prototypes ---- */
    .protos { padding-bottom: var(--spacing-800, 64px); }
    .protos__head { margin-bottom: var(--spacing-400, 16px); }
    .protos__head h2 { margin: 0; font-family: var(--font-display, var(--font-sans)); font-size: var(--type-size-500, 1.5rem); font-weight: var(--font-weight-semibold, 550); color: var(--color-text-primary, #3d3d3d); }
    .protos__head p { margin: var(--spacing-100, 4px) 0 0; color: var(--color-text-secondary, #525252); }
    .proto-list { list-style: none; margin: 0; padding: 0; display: grid; grid-template-columns: 1fr 1fr; gap: var(--spacing-300, 12px); }
    .proto-card {
      position: relative; padding: var(--spacing-400, 16px) var(--spacing-500, 24px);
      border: 1px solid var(--color-border, #dcdcdc); border-radius: var(--radius-300, 8px);
      transition: background-color 0.12s ease, border-color 0.12s ease;
    }
    .proto-card:hover { background: var(--color-primary-subtle, #f3f8fb); border-color: var(--color-primary-border, #cfe2ee); }
    .proto-card__link { display: block; }
    .proto-card__link::after { content: ''; position: absolute; inset: 0; }
    .proto-card__title { display: inline-flex; align-items: center; gap: var(--spacing-150, 6px); font-weight: var(--font-weight-semibold, 550); font-size: var(--type-size-300, 1.0625rem); color: var(--color-text-link, #43608a); }
    .proto-card__arrow { opacity: 0; transition: opacity 0.12s ease; flex: none; }
    .proto-card:hover .proto-card__arrow { opacity: 0.7; }
    .proto-card__desc { margin: var(--spacing-150, 6px) 0 var(--spacing-300, 12px); font-size: var(--type-size-100, 0.9375rem); line-height: 1.5; color: var(--color-text-secondary, #525252); }
    .proto-card__foot { display: flex; flex-wrap: wrap; align-items: center; gap: var(--spacing-300, 12px); }
    .proto-card__meta { font-size: var(--type-size-100, 0.875rem); color: var(--color-text-muted, #7c7c7c); font-variant-numeric: tabular-nums; }

    .lib-status { display: inline-flex; align-items: center; gap: var(--spacing-150, 6px); padding: 2px var(--spacing-250, 10px) 2px var(--spacing-200, 8px); border-radius: var(--radius-full, 999px); font-size: var(--type-size-100, 0.875rem); font-weight: var(--font-weight-medium, 450); white-space: nowrap; }
    .lib-status__dot { width: 8px; height: 8px; border-radius: 50%; flex: none; }
    .lib-status[data-status='live'] { background: #e7f4ec; color: #1a6f3f; }
    .lib-status[data-status='live'] .lib-status__dot { background: #1a9b54; }
    .lib-status[data-status='in-progress'] { background: #fff3e0; color: #b05000; }
    .lib-status[data-status='in-progress'] .lib-status__dot { background: #e0a400; }
    .lib-status[data-status='planned'] { background: var(--color-surface-sunken, #efefef); color: var(--color-text-muted, #7c7c7c); }
    .lib-status[data-status='planned'] .lib-status__dot { background: var(--color-text-muted, #9ca3af); }
    .lib-status[data-status='archived'] { background: var(--color-surface-sunken, #efefef); color: var(--color-text-muted, #7c7c7c); }
    .lib-status[data-status='archived'] .lib-status__dot { background: var(--color-text-muted, #9ca3af); }

    /* ---- Footer ---- */
    .home__foot {
      display: flex; align-items: center; gap: var(--spacing-250, 10px);
      padding: var(--spacing-500, 24px) 0 var(--spacing-800, 64px);
      border-top: 1px solid var(--color-border, #dcdcdc);
      color: var(--color-text-muted, #7c7c7c); font-size: var(--type-size-100, 0.875rem);
    }

    @media (max-width: 720px) { .layers, .proto-list { grid-template-columns: 1fr; } .hero { padding-top: var(--spacing-800, 64px); } }
  </style>
</BaseLayout>
